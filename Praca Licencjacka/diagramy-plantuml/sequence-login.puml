@startuml
!include style.iuml
hide footbox
skinparam ParticipantPadding 24
skinparam BoxPadding 10

autonumber
actor "Przeglądarka (klient)" as K
participant "Middleware Express" as M
participant "Route auth.js" as R
participant "Model User" as U
participant "JWT" as J

K -> M: POST /api/auth/login\n(e-mail, hasło)
M -> R: Przekazanie zadania
R -> U: Pobranie użytkownika po e-mail
U --> R: Dane użytkownika + password_hash
R -> R: Weryfikacja hasła (bcrypt)
R -> J: Generowanie tokenu
J --> R: Token JWT
R --> K: 200 OK + token
K -> K: Zapis tokenu w localStorage
@enduml