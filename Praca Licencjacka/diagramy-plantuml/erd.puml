@startuml
!include style.iuml
title Digital Dungeons - Diagram ER (Baza danych)
left to right direction
skinparam linetype ortho
skinparam shadowing false
skinparam nodesep 140
skinparam ranksep 120
skinparam horizontalLabelDistance 80
skinparam verticalLabelDistance 24
skinparam entityPadding 12

entity "users" as USERS {
  * user_id : INT <<PK>>
  --
  username : VARCHAR
  email : VARCHAR
  password : VARCHAR
  profile_bio : TEXT
  join_date : DATETIME
  last_login : DATETIME
  is_active : BOOLEAN
}

entity "games" as GAMES {
  * game_id : INT <<PK>>
  --
  author_id : INT <<FK>>
  title : VARCHAR
  description : TEXT
  game_content : JSON
  is_published : BOOLEAN
  likes_count : INT
  plays_count : INT
  create_date : DATETIME
  update_date : DATETIME
}

entity "playthroughs" as PLAYTHROUGHS {
  * playthrough_id : INT <<PK>>
  --
  game_id : INT <<FK>>
  user_id : INT <<FK>>
  game_state : JSON
  status : ENUM
  start_date : DATETIME
  last_active : DATETIME
}

entity "comments" as COMMENTS {
  * comment_id : INT <<PK>>
  --
  game_id : INT <<FK>>
  user_id : INT <<FK>>
  content : TEXT
  date_posted : DATETIME
  is_edited : BOOLEAN
}

entity "likes" as LIKES {
  * like_id : INT <<PK>>
  --
  user_id : INT <<FK>>
  game_id : INT <<FK>>
  date_liked : DATETIME
}

GAMES ||--o{ PLAYTHROUGHS : "\nrozgrywki\n0..*"
USERS ||--o{ PLAYTHROUGHS : "gracz\n0..*"
USERS ||--o{ GAMES : "autor\n1..*"
GAMES ||--o{ COMMENTS : "komentarze\n0..*"
USERS ||--o{ COMMENTS : "autor_komentarza\n0..*"
USERS ||--o{ LIKES : "użytkownik\n0..*"
GAMES ||--o{ LIKES : "polubienia\n0..*"

' Hidden edges to influence layout
USERS -[hidden]-> GAMES
GAMES -[hidden]-> PLAYTHROUGHS
GAMES -[hidden]-> COMMENTS
COMMENTS -[hidden]-> LIKES
@enduml
